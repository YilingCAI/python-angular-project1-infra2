# AWS credentials for local Terraform bootstrap runs
# Copy this file to .aws.local.env and fill in your values.
# This file is gitignored — never commit actual credentials.

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Optional: Use a named profile instead of static credentials
# AWS_PROFILE=my-profile
